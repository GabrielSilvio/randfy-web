# API Configuration
# URL base da API backend
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# WebSocket Configuration
# URL do servidor WebSocket para chat em tempo real
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws/chat

# Sentry Configuration (Opcional - para monitoramento de erros)
# DSN do Sentry para rastreamento de erros
NEXT_PUBLIC_SENTRY_DSN=

# Sentry Organization e Project (Opcional - para build com source maps)
SENTRY_ORG=
SENTRY_PROJECT=

# Node Environment (geralmente definido automaticamente)
# NODE_ENV=development
